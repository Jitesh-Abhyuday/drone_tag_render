generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model devices {
  id         Int     @id @default(autoincrement())
  device_id  String? @unique @db.VarChar(100)
  created_at String? @db.VarChar
}

model logs {
  id        Int     @id @default(autoincrement())
  device_id String? @db.VarChar(100)
  latitude  String? @db.VarChar(225)
  longitude String? @db.VarChar(225)
  timestamp String? @db.VarChar
  altitude  String? @db.VarChar(225)
  maplink   String? @db.VarChar
}